# Переменные для локального dev (npm run dev).
# Сводный список имён переменных стека (без значений): exports/platform-state/ENV_KEYS.md
# Чтобы конфиг и поведение совпадали с prod (docker-compose ui), задайте те же переменные.
# Скопируйте в .env или экспортируйте перед запуском: npm run dev

APP_ENV=development
APP_MODE=full
APP_INSTALLATION=opensource
RELEASE_VERSION=2.7.0-night

# Порты dev: клиент (Rspack) + API (Express). В браузере открывайте URL клиента (не порт API).
# Windows (app-builder.config): по умолчанию клиент 3031, API 3040 (3030 часто занят). На Linux/Mac API обычно 3030.
# DEV_CLIENT_PORT=3031
# DEV_SERVER_PORT=3030

# Эндпоинты бэкендов — задайте, если UI в dev, а сервисы в Docker (иначе getAuth 500, предпросмотр датасета 500).
# Порты из datalens/docker-compose.demo.yaml: us → 8030, control-api → 8010, data-api → 8020, us-auth → 8088.
# US_ENDPOINT=http://localhost:8030
# BI_API_ENDPOINT=http://localhost:8010
# BI_DATA_ENDPOINT=http://localhost:8020
# AUTH_ENDPOINT=http://localhost:8088
# US_MASTER_TOKEN=us-master-token
#
# Чеклист: см. datalens/TROUBLESHOOTING.md → «Локальный dev: npm run dev».
# Без BI_DATA_ENDPOINT предпросмотр датасета уйдёт не на тот порт → 500 / ECONNREFUSED.

# --- Редактор групп рейсов (MSSQL, API /api/flight-groups-editor/*) ---
#
# КУДА ВПИСЫВАТЬ (локально):
#   Файл: components/datalens-ui/.env  (в корне пакета datalens-ui, рядом с package.json)
#   Пример полного пути: D:\YDLOS\components\datalens-ui\.env
#   После правок перезапустите dev-сервер (npm run dev), чтобы Express подхватил переменные.
#
# ПРОД / Docker: те же ИМЕНА переменных — в env контейнера UI или в .env, который читает ваш оркестратор.
#
# ШАБЛОН (скопируйте, раскомментируйте, замените ЗАГЛУШКИ на свои значения):
#
# FLIGHT_GROUPS_MSSQL_CONNECTION_STRING=Server=ВАШ_СЕРВЕР,1433;Database=ВАША_БД;User Id=ВАШ_ЛОГИН;Password=ВАШ_ПАРОЛЬ;Encrypt=true;TrustServerCertificate=true
#   Формат как у драйвера node-mssql (одна строка, без кавычек вокруг всей строки, если в пароле нет ; ).
#   Если порт не 1433: Server=host,ПОРТ;
#
# FLIGHT_GROUPS_EDITOR_DATASET_IDS=xxxxxxxxxxxxxxxxxxxxxxxx
#   Entry id датасета в Universal Storage (строка вида 24 символа), через запятую без пробелов.
#   Обычно достаточно ОДНОГО id: датасет на VIEW `vw_FlightsByGroups` (groupID, groupName, flightNo).
#   Если у вас раздельные датасеты (группы / членство) — можно указать 2 id.
#   Где взять id: откройте датасет в интерфейсе — id часто в URL (/datasets/<id> или в карточке сущности).
#   Этот список также отдаётся в window.DL.flightGroupsEditorDatasetIds — кнопка в шапке может
#   появиться сразу при отрисовке, если id уже есть в селекторах на дашборде (без ожидания ответа API).
#
# Опционально:
# FLIGHT_GROUPS_MASTER_FLIGHTS_SQL=(SELECT DISTINCT flightNo FROM dbo.ВашаТаблицаРейсов)
#   Подзапрос с одним столбцом flightNo — для правой колонки «не в группе». Иначе — DISTINCT из таблицы членства.
# FLIGHT_GROUPS_PROTECTED_GROUP_IDS=1
# FLIGHT_GROUPS_TABLE_GROUPS=AZ_FLIGHTS_GROUPS
# FLIGHT_GROUPS_TABLE_MEMBERS=AZ_FLIGHTSinGROUPS
# FLIGHT_GROUPS_EDITOR_TOKEN=случайная_строка_для_защиты_API
#   Если задано — браузер получит тот же токен в window.DL и пошлёт заголовок x-flight-groups-editor-token.
# Вариант с одним VIEW-датасетом (рекомендуемый):
#   Настройте селекторы вручную один раз:
#     - «Группы» -> field = groupName
#     - «Рейсы»  -> field = flightNo
#   и включите dependentSelectors в настройках дашборда.
#
# Минимум для работы API: FLIGHT_GROUPS_MSSQL_CONNECTION_STRING.
# Минимум чтобы кнопка появилась на дашборде: ещё FLIGHT_GROUPS_EDITOR_DATASET_IDS с id ваших датасетов.
