# ============================================================
# YDL OS - BI-Platform Environment Configuration
# ============================================================
# Скопируйте в .env и измените значения

# --- Общие ---
APP_ENV=prod
RELEASE_VERSION=2.9.0

# --- Порты ---
UI_PORT=8080

# --- PostgreSQL (метаданные) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=pg-user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB_US=pg-us-db
POSTGRES_DB_COMPENG=pg-compeng-db
POSTGRES_DB_AUTH=pg-auth-db
POSTGRES_DB_META_MANAGER=pg-meta-manager-db
POSTGRES_DB_TEMPORAL=pg-temporal-db
POSTGRES_DB_TEMPORAL_VISIBILITY=pg-temporal-visibility-db
POSTGRES_DB_DEMO=pg-demo-db

# --- Инициализация ---
INIT_DEMO_DATA=0
INIT_DB_DEMO=0
INIT_DB_AUTH=1
INIT_DB_META_MANAGER=1
INIT_DB_TEMPORAL=1

# --- Безопасность ---
CONTROL_API_CRYPTO_KEY=CHANGE_ME_BASE64_KEY
US_MASTER_TOKEN=CHANGE_ME_US_MASTER_TOKEN
AUTH_MASTER_TOKEN=CHANGE_ME_AUTH_MASTER_TOKEN

# --- Аутентификация ---
AUTH_ENABLED=true
AUTH_SIGNUP_DISABLED=true
AUTH_KEY_MODE=false

# --- OIDC (Keycloak SSO) ---
OIDC=true
# Для production: https://keycloak.aeronavigator.ru/realms/meridian-demo
OIDC_ISSUER=http://host.docker.internal:8090/realms/meridian-demo
OIDC_BASE_URL=https://bi.aeronavigator.ru
OIDC_CLIENT_ID=datalens-client
OIDC_SECRET=CHANGE_ME_KEYCLOAK_CLIENT_SECRET
OIDC_NAME=Keycloak

# --- Таблицы ---
FLAT_TABLE_ROWS_LIMIT=100000
DATA_FETCHING_TIMEOUT_MS=120
DATA_SINGLE_FETCHING_TIMEOUT_MS=120

# --- Карты ---
YANDEX_MAP_ENABLED=0
YANDEX_MAP_TOKEN=

# --- Highcharts (переменные из upstream; в YDL-OS CDN Highcharts в UI отключён в коде, см. CHARTS_AND_LICENSES.md) ---
HC=0
HC_ENDPOINT=
HC_PROTOCOL=https

# --- Export ---
EXPORT_WORKBOOK_ENABLED=true
EXPORT_DASH_EXCEL=true

# --- IPv6 ---
IS_IPV6=false
