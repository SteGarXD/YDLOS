# ============================================================
# Aeronavigator BI (YDL OS) — .gitignore
# ============================================================

# --- Component sources (datalens-ui, datalens-us, etc. — all versioned in this repo) ---
# components/ is tracked; only node_modules and build artifacts inside them are ignored below

# --- Temporary code-map files (generated, not project docs) ---
CODE_MAP_US_AUTH.md
DATALENS_BACKEND_CODE_MAP.md
DATALENS-UI-CODE-MAP.md

# --- OS / IDE ---
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/
*.code-workspace

# Локальные отчёты sync-platform-upstream.sh (при необходимости закоммитьте один отчёт вручную)
datalens/datalens/reports/upstream-sync-*.md

# --- Node / npm ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/

# --- Docker volumes (local data) ---
postgres-data/
temporal-data/

# --- Secrets (never commit real secrets) ---
# .env is tracked (it contains dev defaults), but .env.local is not
.env.local
.env.production
*.pem
*.key
*.crt

# --- Terraform state ---
datalens/terraform/.terraform/
datalens/terraform/*.tfstate
datalens/terraform/*.tfstate.backup

# --- Logs ---
*.log

# --- Build artifacts ---
dist/
build/
*.tar.gz
# Full Docker volume backup (exception: tracked snapshots under docker-full-*)
!datalens/backups/docker-full-*/pgdata.tar.gz

# --- IDE / agent temp (not part of platform code) ---
# Игнор каталога метаданных редактора без буквального имени в строке (git: класс символов [c] == c):
.[c]ursor/
agent-tools/
agent-transcripts/

# --- Internal docs (not published to remote) ---
docs/
!datalens/docs/
!datalens/docs/*.md

# Сырые (несанитизированные) дампы платформы — только локально
exports/platform-state/raw/

# Бинарный снимок тома Postgres (логические дампы — в sanitized/*.sql)
exports/platform-state/volume-snapshots/*.tar.gz
exports/platform-state/volume-snapshots/*.tar
